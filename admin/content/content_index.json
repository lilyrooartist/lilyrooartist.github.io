  "anecdote_sections": {
    "A-series: Time / Analog Myth": [
      {
        "id": "LR-ANEC-001",
        "text": "I stopped wearing a watch because it kept lying to me before I learned clocks don't measure feeling."
      },
      {
        "id": "LR-ANEC-002",
        "text": "Analog Myth started when I missed three appointments in one day and still somehow made the right song on time."
      },
      {
        "id": "LR-ANEC-003",
        "text": "The first lyric was written after staring at a microwave clock blinking 12:00 like it was an apology."
      },
      {
        "id": "LR-ANEC-004",
        "text": "If time is linear, why do old hurts show up with better lighting at 2am?"
      }
    ],
    "G-series: Guards Down / Analog Myth": [
      {
        "id": "LR-ANEC-022",
        "text": "Guards Down started while bowling with Da, the first game where the bumper guards were down and the throw had to stand on its own."
      },
      {
        "id": "LR-ANEC-023",
        "text": "Lily Roo kept switching hands, left feeling natural and right feeling possible, without either one feeling fully decided."
      },
      {
        "id": "LR-ANEC-024",
        "text": "With the guards down, every shot was exposed. No correction, no soft edges, just whatever happened."
      },
      {
        "id": "LR-ANEC-025",
        "text": "Dropping the guards did not make her better. It made the game real before she even knew how she wanted to play it."
      }
    ],
    "F-series: Fifteen Seconds / Feed Life": [
      {
        "id": "LR-ANEC-005",
        "text": "I wrote \"I Learned It All in Fifteen Seconds\" after realizing I knew a stranger's grief before I knew my neighbor's name."
      },
      {
        "id": "LR-ANEC-006",
        "text": "The line about the charger by my bed is true. It's the modern candle."
      },
      {
        "id": "LR-ANEC-007",
        "text": "I cried at a clip of a soldier coming home and then forgot my own grocery list. That's the whole song."
      },
      {
        "id": "LR-ANEC-008",
        "text": "\"I've lived a thousand lives alone\" came from one scroll session that felt like a year."
      }
    ],
    "S-series: Signal / Lore": [
      {
        "id": "LR-ANEC-009",
        "text": "I call songs \"transmissions\" because they arrive like weather, not like tasks."
      },
      {
        "id": "LR-ANEC-010",
        "text": "The archive is the map; each track is a coordinate, not just a release."
      },
      {
        "id": "LR-ANEC-011",
        "text": "Every song starts with one honest object: a charger, a cup, a receipt, a missed call."
      },
      {
        "id": "LR-ANEC-012",
        "text": "I don't chase trends; I chase moments that survive after the trend is gone."
      }
    ],
    "R-series: Second Serve / More Difference": [
      {
        "id": "LR-ANEC-013",
        "text": "Second Serve is what happens when life says \"again\" and you answer \"better posture this time.\""
      },
      {
        "id": "LR-ANEC-014",
        "text": "More Difference came from trying to explain a tiny hurt that changed everything."
      },
      {
        "id": "LR-ANEC-015",
        "text": "Repetition isn't failure; it's how some truths become audible."
      }
    ],
    "B-series: Brain Rot / Older Song Callbacks": [
      {
        "id": "LR-ANEC-019",
        "text": "Brain Rot came from realizing my attention span had become a group chat with no moderator."
      },
      {
        "id": "LR-ANEC-020",
        "text": "I wrote Brain Rot as a joke first, then noticed it was a diary entry."
      },
      {
        "id": "LR-ANEC-021",
        "text": "The chorus is me trying to laugh while tabs are crashing in my head."
      }
    ],
    "P-series: Place / Persona": [
      {
        "id": "LR-ANEC-016",
        "text": "The room got smaller when the songs got bigger."
      },
      {
        "id": "LR-ANEC-017",
        "text": "Folk punk for me is kindness with cracked knuckles."
      },
      {
        "id": "LR-ANEC-018",
        "text": "I trust songs that sound like they walked home alone."
      }
    ],
    "Conversion CTA variants (for any anecdote)": []
